generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CacheRecord {
  id        String   @id @default(cuid())
  url       String   @unique
  urlHash   String   @unique
  fileName  String
  fileSize  Int
  cachePath String
  createdAt DateTime @default(now())
  expiresAt DateTime
  accessedAt DateTime @default(now())
}